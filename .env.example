# Supabase の接続文字列(Transaction pooler / port 6543 のものを推奨)
DATABASE_URL=postgresql://postgres.xxxx:password@aws-0-ap-northeast-1.pooler.supabase.com:6543/postgres

# LINE Developers コンソール > Messaging API チャネルから取得
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=

# (任意)2つ目のLINEチャネル。無料枠をグループ分散するときに設定する
# ※必ずチャネル1と同一プロバイダー配下に作成すること(READMEの「チャネルを増やす」参照)
# LINE_CHANNEL_2_ACCESS_TOKEN=
# LINE_CHANNEL_2_SECRET=

# 管理画面のログインID/パスワード。セッションcookieの署名鍵の材料も兼ねるので、
# パスワードを変更するとログイン中の全員がログアウトされる(流出時の失効手段)
ADMIN_USER=admin
ADMIN_PASSWORD=

# /api/cron/tick を叩く外部cron用のシークレット(ランダムな長い文字列)
CRON_SECRET=

# (任意)アプリの公開URL。アナウンスに載せる参加状況ページ(/p/…)のリンク生成に使う
# Vercel なら未設定でOK(VERCEL_PROJECT_PRODUCTION_URL から自動解決)。独自ドメイン等で上書きしたいときだけ設定
# APP_BASE_URL=https://example.com

# (任意)運営マニュアル限定公開ページ(/p/docs/<token>)のシークレットトークン。
# 未設定ならページ自体が404(機能オフ)。`openssl rand -hex 16` などで生成する
# ※このURLを知っている人は管理画面のID/パスワードまで見られる。流出したら値を変えて再デプロイ
# DOCS_TOKEN=

# (任意)Slack Incoming Webhook URL。日程調整の締切自動取込結果の通知に使う
# 未設定なら通知をスキップする(締切検知・自動取込そのものは動く)
# SLACK_WEBHOOK_URL=

# ── ここから下はアプリ本体(getEnv())は読まない。Claude Code の Supabase MCP
#    (.mcp.json)が ${SUPABASE_PROJECT_REF} / ${SUPABASE_ACCESS_TOKEN} として参照する設定 ──

# 上の DATABASE_URL のユーザー名部分(postgres.<ref>の<ref>)がそのままproject ref。
# 新たに調べる必要はなく、DATABASE_URLからコピーするだけでよい
# SUPABASE_PROJECT_REF=

# 個人アクセストークン。https://supabase.com/dashboard/account/tokens で発行
# (表示は発行時の一度きりなので、発行したらすぐここに貼る)
# SUPABASE_ACCESS_TOKEN=
